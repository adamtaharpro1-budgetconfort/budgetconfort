generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ AUTH ============

enum GlobalRole {
  USER
  ADMIN
  SUPERADMIN
}

enum HouseholdRole {
  OWNER
  MEMBER
  CHILD
}

enum HouseholdType {
  SOLO
  COUPLE
  FAMILY
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  passwordHash    String?
  firstName       String?
  lastName        String?
  image           String?
  birthDate       DateTime?
  sex             String?
  height          Float?
  weight          Float?
  language        String    @default("fr")
  currency        String    @default("EUR")
  country         String?
  timezone        String    @default("Europe/Paris")
  role            GlobalRole @default(USER)
  onboardingDone  Boolean   @default(false)
  xp              Int       @default(0)
  dailyScore      Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  householdMemberships HouseholdMember[]
  nutritionProfile     NutritionProfile?
  dailyLogs            DailyNutritionLog[]
  incomes              Income[]
  transactions         Transaction[]
  notifications        Notification[]
  chatMessages         ChatMessage[]
  userChallenges       UserChallenge[]
  userBadges           UserBadge[]
  receipts             Receipt[]
  favoriteRecipes      RecipeFavorite[]
  connectionLogs       ConnectionLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  type       String   @default("email_verification") // email_verification | password_reset

  @@unique([identifier, token])
}

model ConnectionLog {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ HOUSEHOLD ============

model Household {
  id            String        @id @default(cuid())
  name          String
  type          HouseholdType @default(SOLO)
  budgetMonthly Float?
  currency      String        @default("EUR")
  createdAt     DateTime      @default(now())

  members          HouseholdMember[]
  incomes          Income[]
  fixedExpenses    FixedExpense[]
  transactions     Transaction[]
  goals            FinancialGoal[]
  trips            Trip[]
  mealPlanEntries  MealPlanEntry[]
  pantryItems      PantryItem[]
  shoppingLists    ShoppingList[]
  receipts         Receipt[]
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String? // null for profile-only members without their own login (e.g. children)
  role        HouseholdRole @default(MEMBER)
  label       String? // "Papa", "Maman", "Enfant 1"
  canEditBudget Boolean @default(true)
  joinedAt    DateTime      @default(now())

  // Lightweight profile fields for members without a full User account
  isChild     Boolean  @default(false)
  age         Int?
  sex         String?
  height      Float?
  weight      Float?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
}

// ============ FINANCE ============

enum IncomeType {
  SALAIRE
  PRIME
  FREELANCE
  CAF
  AUTRE
}

model Income {
  id          String     @id @default(cuid())
  householdId String
  userId      String?
  label       String
  amount      Float
  type        IncomeType @default(SALAIRE)
  recurring   Boolean    @default(true)
  date        DateTime   @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model FixedExpense {
  id          String   @id @default(cuid())
  householdId String
  label       String
  category    String
  amount      Float
  dueDay      Int?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

enum VariableExpenseCategory {
  RESTAURANT
  SHOPPING
  ESSENCE
  VOYAGES
  LOISIRS
  SANTE
  ANIMAUX
  ENFANTS
  COURSES
  AUTRE
}

enum TransactionSource {
  MANUAL
  RECEIPT_SCAN
  AI
}

model Transaction {
  id          String                   @id @default(cuid())
  householdId String
  userId      String?
  label       String
  category    VariableExpenseCategory
  amount      Float
  date        DateTime                 @default(now())
  source      TransactionSource        @default(MANUAL)
  receiptId   String?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  receipt   Receipt?   @relation(fields: [receiptId], references: [id], onDelete: SetNull)
}

enum GoalType {
  MAISON
  VOITURE
  VACANCES
  MARIAGE
  URGENCE
  ENTREPRISE
  RETRAITE
  AUTRE
}

model FinancialGoal {
  id                 String   @id @default(cuid())
  householdId        String
  name               String
  type               GoalType @default(AUTRE)
  targetAmount       Float
  currentAmount      Float    @default(0)
  targetDate         DateTime?
  weeklyContribution Float?
  createdAt          DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model Trip {
  id                String    @id @default(cuid())
  householdId       String
  destination       String
  startDate         DateTime?
  endDate           DateTime?
  budgetTotal        Float?
  budgetTransport    Float?
  budgetHotel        Float?
  budgetRestaurants  Float?
  budgetActivities   Float?
  notes             String?
  createdAt         DateTime  @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

// ============ MEALS & NUTRITION ============

enum Difficulty {
  FACILE
  MOYEN
  DIFFICILE
}

model Recipe {
  id            String     @id @default(cuid())
  name          String
  photo         String?
  prepTime      Int? // minutes
  difficulty    Difficulty @default(FACILE)
  calories      Int?
  priceEstimate Float?
  proteins      Float?
  carbs         Float?
  fats          Float?
  servings      Int        @default(2)
  steps         Json // string[]
  cuisine       String?
  isAiGenerated Boolean    @default(false)
  createdAt     DateTime   @default(now())

  ingredients     RecipeIngredient[]
  mealPlanEntries MealPlanEntry[]
  favoritedBy     RecipeFavorite[]
}

model RecipeIngredient {
  id       String  @id @default(cuid())
  recipeId String
  name     String
  quantity Float?
  unit     String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeFavorite {
  id       String @id @default(cuid())
  userId   String
  recipeId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model MealPlanEntry {
  id          String   @id @default(cuid())
  householdId String
  date        DateTime
  mealType    MealType
  recipeId    String?
  servings    Int      @default(2)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipe    Recipe?   @relation(fields: [recipeId], references: [id], onDelete: SetNull)
}

model NutritionProfile {
  userId          String   @id
  sex             String?
  age             Int?
  height          Float?
  weight          Float?
  goal            String? // LOSE, MAINTAIN, GAIN
  activityLevel   String? // SEDENTARY, LIGHT, MODERATE, ACTIVE, VERY_ACTIVE
  allergies       String[]
  preferences     String[]
  forbiddenFoods  String[]
  bmr             Float?
  tdee            Float?
  calorieTarget   Int?
  proteinTarget   Int?
  carbTarget      Int?
  fatTarget       Int?
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyNutritionLog {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime @default(now())
  caloriesConsumed  Int      @default(0)
  proteins          Float    @default(0)
  carbs             Float    @default(0)
  fats              Float    @default(0)
  waterMl           Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ============ STOCK & COURSES ============

model PantryItem {
  id          String    @id @default(cuid())
  householdId String
  name        String
  quantity    Float?
  unit        String?
  category    String?
  expiryDate  DateTime?
  photo       String?
  addedAt     DateTime  @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

enum ShoppingListStatus {
  ACTIVE
  DONE
  ARCHIVED
}

model ShoppingList {
  id          String             @id @default(cuid())
  householdId String
  name        String             @default("Courses")
  status      ShoppingListStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())

  household Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id       String  @id @default(cuid())
  listId   String
  name     String
  quantity Float?
  unit     String?
  category String?
  checked  Boolean @default(false)

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
}

enum ReceiptStatus {
  PENDING
  PROCESSED
  FAILED
}

model Receipt {
  id          String        @id @default(cuid())
  householdId String
  userId      String?
  imageUrl    String
  store       String?
  total       Float?
  date        DateTime?
  rawExtraction Json?
  status      ReceiptStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  transactions Transaction[]
}

// ============ GAMIFICATION ============

model Challenge {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String // BUDGET, NUTRITION, CUISINE, GASPILLAGE, EPARGNE, SPORT
  target      Int
  xpReward    Int      @default(10)
  createdAt   DateTime @default(now())

  userChallenges UserChallenge[]
}

model UserChallenge {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model Badge {
  id          String @id @default(cuid())
  name        String
  icon        String?
  description String?

  userBadges UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ============ NOTIFICATIONS & CHAT ============

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // BUDGET, REPAS, COURSES, OBJECTIF, PEREMPTION, DEPASSEMENT, CONSEIL_IA
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String // user | assistant
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
